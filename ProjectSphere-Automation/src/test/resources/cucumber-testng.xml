<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    Cucumber BDD Test Suite — runs independently of the existing testng.xml.

    Run from IntelliJ terminal:
      mvn test -DsuiteFile=src/test/resources/cucumber-testng.xml

    Run with tag filter:
      mvn test -DsuiteFile=src/test/resources/cucumber-testng.xml -Dcucumber.filter.tags="@smoke"
      mvn test -DsuiteFile=src/test/resources/cucumber-testng.xml -Dcucumber.filter.tags="@admin"
      mvn test -DsuiteFile=src/test/resources/cucumber-testng.xml -Dcucumber.filter.tags="@pm"
      mvn test -DsuiteFile=src/test/resources/cucumber-testng.xml -Dcucumber.filter.tags="@regression"
-->
<suite name="ProjectSphere Cucumber BDD Suite" verbose="1">

    <test name="Cucumber BDD Tests">
        <classes>
            <class name="com.projectsphere.automation.cucumber.runner.CucumberRunner"/>
        </classes>
    </test>

</suite>
